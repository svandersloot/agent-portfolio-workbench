ATLASSIAN_SITE=<your-atlassian-site-url>
CONFLUENCE_SPACE_KEY=ROVO
CONFLUENCE_API_BASE=<your-confluence-api-base-url>

# Optional future publishing targets. Use page IDs, not titles, once pages exist.
CONFLUENCE_MEASUREMENT_PAGE_ID=
CONFLUENCE_CONTEXT_READINESS_PAGE_ID=
CONFLUENCE_USER_GUIDE_PAGE_ID=
CONFLUENCE_AGENT_INVENTORY_PAGE_ID=
CONFLUENCE_LEGACY_AGENT_INVENTORY_PAGE_ID=

# Do not commit a real API token.
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=replace-me
