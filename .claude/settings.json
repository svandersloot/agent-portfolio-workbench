{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status -s)",
      "Bash(git status --short)",
      "Bash(git status --porcelain)",
      "Bash(git diff)",
      "Bash(git diff --check)",
      "Bash(git diff --stat)",
      "Bash(git diff --staged)",
      "Bash(git diff --cached)",
      "Bash(git diff --name-only)",
      "Bash(git diff --name-status)",
      "Bash(git log)",
      "Bash(git log --oneline)",
      "Bash(git log --oneline -10)",
      "Bash(git log --oneline -20)",
      "Bash(git log --stat)",
      "Bash(git log --graph --oneline)",
      "Bash(git show)",
      "Bash(git show --stat)",
      "Bash(git show --name-only)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git branch --list)",
      "Bash(git branch -a)",
      "Bash(git branch -v)",
      "Bash(git branch -vv)",
      "Bash(ls)",
      "Bash(ls -la)",
      "Bash(pwsh -NoProfile -File ./scripts/Test-PrivateDataScan.ps1)",
      "Bash(pwsh -NoProfile -File ./scripts/Test-PrivateDataScan.ps1 -Scope AllTracked -WarnOnly)",
      "Bash(pwsh -NoProfile -File ./scripts/Test-StaleHandoffs.ps1)",
      "Bash(pwsh -NoProfile -File ./scripts/Test-ConfluencePageFamilyConsistency.ps1)",
      "Bash(pwsh -NoProfile -File ./scripts/Test-ConfluenceStorageConversion.ps1)",
      "Bash(pwsh -NoProfile -File ./scripts/Test-GovernanceReportInputs.ps1)"
    ],
    "ask": [
      "Bash(.\\scripts\\Publish-ConfluencePages.ps1:*)",
      "Bash(./scripts/Publish-ConfluencePages.ps1:*)",
      "Bash(powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Publish-ConfluencePages.ps1:*)",
      "Bash(pwsh -NoProfile -File .\\scripts\\Publish-ConfluencePages.ps1:*)",
      "Bash(pwsh -NoProfile -File ./scripts/Publish-ConfluencePages.ps1:*)",
      "Bash(.\\scripts\\Sync-ConfluenceLocalManifest.ps1:*)",
      "Bash(./scripts/Sync-ConfluenceLocalManifest.ps1:*)",
      "Bash(powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Sync-ConfluenceLocalManifest.ps1:*)",
      "Bash(pwsh -NoProfile -File .\\scripts\\Sync-ConfluenceLocalManifest.ps1:*)",
      "Bash(pwsh -NoProfile -File ./scripts/Sync-ConfluenceLocalManifest.ps1:*)",
      "Bash(pwsh -NoProfile -File ./scripts/Inspect-StudioHar.ps1:*)",
      "Bash(pwsh -NoProfile -File .\\scripts\\Inspect-StudioHar.ps1:*)",
      "Bash(pwsh -NoProfile -File ./scripts/Extract-StudioResponsesFromHar.ps1:*)",
      "Bash(pwsh -NoProfile -File .\\scripts\\Extract-StudioResponsesFromHar.ps1:*)",
      "Bash(pwsh -NoProfile -File ./scripts/Normalize-StudioExport.ps1:*)",
      "Bash(pwsh -NoProfile -File .\\scripts\\Normalize-StudioExport.ps1:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Edit(./.env)",
      "Write(./.env)",
      "Read(./.env.*)",
      "Edit(./.env.*)",
      "Write(./.env.*)",
      "Read(./config/confluence-pages.yml)",
      "Edit(./config/confluence-pages.yml)",
      "Write(./config/confluence-pages.yml)",
      "Read(./config/studio-agents.yml)",
      "Edit(./config/studio-agents.yml)",
      "Write(./config/studio-agents.yml)",
      "Read(./config/atlassian-knowledge-inventory.yml)",
      "Edit(./config/atlassian-knowledge-inventory.yml)",
      "Write(./config/atlassian-knowledge-inventory.yml)",
      "Read(./data/raw/**)",
      "Edit(./data/raw/**)",
      "Write(./data/raw/**)",
      "Read(./data/exports/**)",
      "Edit(./data/exports/**)",
      "Write(./data/exports/**)",
      "Read(./docs/private-overlays/**)",
      "Edit(./docs/private-overlays/**)",
      "Write(./docs/private-overlays/**)",
      "Read(**/*.har)",
      "Edit(**/*.har)",
      "Write(**/*.har)",
      "Read(**/*cookie*.json)",
      "Edit(**/*cookie*.json)",
      "Write(**/*cookie*.json)",
      "Read(**/*token*.json)",
      "Edit(**/*token*.json)",
      "Write(**/*token*.json)",
      "Read(**/*secret*.json)",
      "Edit(**/*secret*.json)",
      "Write(**/*secret*.json)",
      "Read(**/*credential*.json)",
      "Edit(**/*credential*.json)",
      "Write(**/*credential*.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": [
              "-NoProfile",
              "-File",
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/Deny-SecretRead.ps1"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
