{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(Get-Content*)",
      "Bash(Test-Path*)"
    ],
    "deny": [
      "Read(./.env)",
      "Edit(./.env)",
      "Write(./.env)",
      "Read(./config/confluence-pages.yml)",
      "Edit(./config/confluence-pages.yml)",
      "Write(./config/confluence-pages.yml)",
      "Read(./data/raw/**)",
      "Edit(./data/raw/**)",
      "Write(./data/raw/**)",
      "Edit(**/*har*)",
      "Write(**/*har*)",
      "Edit(**/*cookie*)",
      "Write(**/*cookie*)",
      "Edit(**/*token*)",
      "Write(**/*token*)",
      "Edit(**/*secret*)",
      "Write(**/*secret*)",
      "Edit(**/*credential*)",
      "Write(**/*credential*)"
    ]
  }
}
