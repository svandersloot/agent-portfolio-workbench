{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/rovo-governance-admin/jira-work-item-draft-bundle.schema.json",
  "title": "Jira Work Item Draft Bundle",
  "description": "Structured handoff from Jira Work Item Assistant to Jira Ticket Polisher before any Jira work item is created.",
  "type": "object",
  "required": [
    "schemaVersion",
    "handoffType",
    "createdByAgent",
    "createdAt",
    "workContext",
    "kanbanContext",
    "requestedOutcome",
    "tickets",
    "approval"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "handoffType": { "const": "jira-work-item-draft" },
    "createdByAgent": { "const": "Jira Work Item Assistant" },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 date-time or explicit local timestamp supplied by the agent or automation."
    },
    "workContext": {
      "type": "object",
      "required": ["workName"],
      "properties": {
        "workName": { "type": "string", "minLength": 1 },
        "workType": { "type": "string" },
        "releaseName": { "type": "string", "minLength": 1 },
        "releaseDate": { "type": "string" },
        "fixVersion": { "type": "string" },
        "releaseStage": { "type": "string" },
        "sourceLinks": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceLink" }
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "kanbanContext": {
      "type": "object",
      "properties": {
        "boardName": { "type": "string" },
        "boardId": { "type": "string" },
        "projectKey": { "type": "string" },
        "targetColumn": { "type": "string" },
        "rankOrPlacement": { "type": "string" },
        "visibleContextSummary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "requestedOutcome": {
      "type": "string",
      "description": "What the user asked Jira Work Item Assistant to create, coordinate, or prepare.",
      "minLength": 1
    },
    "tickets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ticketDraft" }
    },
    "approval": {
      "type": "object",
      "required": ["humanApprovalRequired", "approvedForJiraWrite"],
      "properties": {
        "humanApprovalRequired": { "const": true },
        "approvedForJiraWrite": { "const": false },
        "approvalPrompt": { "type": "string" },
        "approver": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sourceLink": {
      "type": "object",
      "required": ["label", "urlOrKey"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "urlOrKey": { "type": "string", "minLength": 1 },
        "sourceType": {
          "enum": ["Jira", "Confluence", "Bitbucket", "Slack", "User Provided", "Other"]
        },
        "authority": {
          "enum": ["System of Record", "Process Authority", "Reference", "User Context", "Unknown"]
        }
      },
      "additionalProperties": false
    },
    "ticketDraft": {
      "type": "object",
      "required": [
        "localDraftId",
        "issueType",
        "summary",
        "description",
        "sourceEvidence",
        "openQuestions"
      ],
      "properties": {
        "localDraftId": { "type": "string", "minLength": 1 },
        "projectKey": { "type": "string" },
        "issueType": {
          "enum": ["Epic", "Story", "Task", "Bug", "Spike", "Sub-task", "Other"]
        },
        "parentKey": { "type": "string" },
        "summary": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "acceptanceCriteria": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "testingNotes": { "type": "string" },
        "releaseNotes": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "risks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "components": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fixVersions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "priority": { "type": "string" },
        "assignee": { "type": "string" },
        "sourceEvidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceLink" }
        },
        "openQuestions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "confidence": {
          "enum": ["High", "Medium", "Low", "Unknown"]
        }
      },
      "additionalProperties": false
    }
  }
}
